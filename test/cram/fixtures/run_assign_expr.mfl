extern int printf(char* fmt, ...);

int main() {
    int x = 0;
    int y = (x = 42);
    printf("%d\n", y);
    printf("%d\n", x);
    int a = 0;
    int b = 0;
    a = b = 10;
    printf("%d\n", a);
    printf("%d\n", b);
    int n = 5;
    if (n = 0) {
        printf("%d\n", 1);
    } else {
        printf("%d\n", 0);
    }
    printf("%d\n", n);
}
