int main() {
    float f = 1.5f;
    double d = 2.25;

    printint((int)(f + 2));
    printint((int)(d - f));
    printint((int)(f * d));
    printint((int)(d / 0.5));

    printbool(f < d);
    printbool(f == 1.5f);
    printbool((bool)f);
    printbool((bool)0.0);

    float x = 1.0f;
    printint((int)(++x));
    printint((int)x);

    double y = 2.0;
    printint((int)(y++));
    printint((int)y);
}
