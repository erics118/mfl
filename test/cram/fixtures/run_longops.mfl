extern int printf(char* fmt, ...);

int main() {
    long a = 2147483647;
    long b = a + 1;
    printf("%d\n", (int)b);

    long x = 1000000000;
    long y = x * x;
    printf("%d\n", (int)y);

    long neg = -999999999;
    printf("%d\n", (int)(neg / 100));
    printf("%d\n", (int)(neg % 1000));

    long c = 2147483647;
    long d = -2147483648;
    printf("%d\n", (int)(c + d));
}
