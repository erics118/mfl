extern int printf(char* fmt, ...);

int main() {
    unsigned int a = 4294967295;
    unsigned int b = a + 1;
    printf("%d\n", (int)b);

    unsigned int c = 0;
    unsigned int d = c - 1;
    printf("%d\n", (int)d);

    unsigned int x = 2147483648;
    unsigned int y = x * 2;
    printf("%d\n", (int)y);

    unsigned int p = 100;
    unsigned int q = 3;
    printf("%d\n", (int)(p / q));
    printf("%d\n", (int)(p % q));
}
