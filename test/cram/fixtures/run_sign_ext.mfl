extern int printf(char* fmt, ...);

int main() {
    char sc = -1;
    int si = sc;
    printf("%d\n", si);
    unsigned char uc = 255;
    int ui = uc;
    printf("%d\n", ui);
    short ss = -1;
    int ssi = ss;
    printf("%d\n", ssi);
    unsigned short us = 65535;
    int usi = us;
    printf("%d\n", usi);
}
