extern int printf(char* fmt, ...);

int main() {
    char a = 100;
    char b = 100;
    int sum = a + b;
    printf("%d\n", sum);
    unsigned char ua = 200;
    unsigned char ub = 200;
    int usum = ua + ub;
    printf("%d\n", usum);
    short sa = 30000;
    short sb = 10000;
    int ssum = sa + sb;
    printf("%d\n", ssum);
}
