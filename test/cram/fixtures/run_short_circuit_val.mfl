extern int printf(char* fmt, ...);

int main() {
    int x = 5;
    int y = 3;
    int a = x && y;
    int b = x || y;
    int c = 0 && y;
    int d = 0 || y;
    int e = x && 0;
    int f = x || 0;
    printf("%d\n", a);
    printf("%d\n", b);
    printf("%d\n", c);
    printf("%d\n", d);
    printf("%d\n", e);
    printf("%d\n", f);
}
