int main() {
    int i;
    for (;;) {
        return 0;
    }
    for (i = 0;;) {
        return i;
    }
    for (; i < 10;) {
        ++i;
    }
    for (;; ++i) {
        return i;
    }
    for (int j = 0; j < 10;) {
        ++j;
    }
    for (int j = 0;; ++j) {
        return j;
    }
    for (; i < 10; ++i) {}
    return i;
}
