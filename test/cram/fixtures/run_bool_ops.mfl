extern int printf(char* fmt, ...);

int main() {
    printf("%d\n", (bool)0);
    printf("%d\n", (bool)1);
    printf("%d\n", (bool)42);
    printf("%d\n", (bool)(-1));
    printf("%d\n", 1 == 1);
    printf("%d\n", 1 == 2);
    printf("%d\n", 1 != 2);
    printf("%d\n", 3 > 2);
    printf("%d\n", 2 > 3);

    bool t = true;
    bool f = false;
    printf("%d\n", t && t);
    printf("%d\n", t && f);
    printf("%d\n", f && t);
    printf("%d\n", f || t);
    printf("%d\n", f || f);
    printf("%d\n", !t);
    printf("%d\n", !f);
}
