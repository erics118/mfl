extern int printf(char* fmt, ...);

int main() {
    printf("%d\n", (int)(char)300);
    printf("%d\n", (int)(char)(-300));
    printf("%d\n", (int)(short)100000);
    printf("%d\n", (int)(unsigned char)(-1));
    printf("%d\n", (int)(unsigned short)(-1));
    printf("%d\n", (int)(bool)0);
    printf("%d\n", (int)(bool)42);
    printf("%d\n", (int)(bool)(-1));

    long big = 1000000000;
    big = big * 10;
    printf("%d\n", (int)big);
}
