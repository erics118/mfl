extern int printf(char* fmt, ...);

int main() {
    char a = 127;
    a++;
    printf("%d\n", (int)a);

    unsigned char b = 200;
    printf("%d\n", (int)b);

    unsigned char c = 255;
    c++;
    printf("%d\n", (int)c);

    char d = -1;
    printf("%d\n", (int)d);

    unsigned char e = 255;
    printf("%d\n", (int)e);

    char f = -128;
    f--;
    printf("%d\n", (int)f);
}
