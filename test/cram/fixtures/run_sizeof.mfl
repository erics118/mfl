extern int printf(char* fmt, ...);

int main() {
    int x;
    char c;
    bool b;
    int* p;
    int arr[3];

    printf("%d\n", sizeof x);
    printf("%d\n", sizeof c);
    printf("%d\n", sizeof b);
    printf("%d\n", sizeof p);
    printf("%d\n", sizeof arr);
    printf("%d\n", sizeof(int));
    printf("%d\n", sizeof(char));
    printf("%d\n", sizeof(bool));
    printf("%d\n", sizeof(int*));
    return 0;
}
