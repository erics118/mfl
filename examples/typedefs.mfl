typedef int myint;
typedef int* intptr;
typedef int numbers[4];

myint sum(intptr values) {
    myint total = 0;
    myint i = 0;

    while (i < 4) {
        total = total + values[i];
        ++i;
    }

    return total;
}

void incr(intptr p) {
    *p = *p + 1;
}

int main() {
    numbers values;
    myint total = 0;

    values[0] = 3;
    values[1] = 1;
    values[2] = 4;
    values[3] = 1;

    total = sum(values);
    incr(&total);
    printint(total);
    return 0;
}
