#include <stdio.h>
#include <stdbool.h>

int main() {
    for (int n = 2; n < 100; ++n) {
        bool is_prime = true;

        for (int d = 2; d * d <= n; ++d) {
            if (n % d == 0) {
                is_prime = false;
                break;
            }
        }

        if (is_prime) printf("%d\n", n);
    }

    return 0;
}
